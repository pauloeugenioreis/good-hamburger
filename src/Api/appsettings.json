{
  "AppSettings": {
    "EnvironmentName": "Development",
    "Infrastructure": {
      "Cache": {
        "Enabled": true,
        "Provider": "Memory",
        "ConnectionString": "",
        "DefaultExpirationMinutes": 60
      },
      "Database": {
        "DatabaseType": "SqlServer",
        "ConnectionString": "Server=localhost,1433;Database=GoodHamburger;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;",
        "ReadOnlyConnectionString": "",
        "CommandTimeoutSeconds": 30,
        "EnableSensitiveDataLogging": false,
        "EnableDetailedErrors": false
      },
      "RateLimiting": {
        "Enabled": false,
        "DefaultPolicy": "fixed",
        "WhitelistedIps": [

        ],
        "Policies": {
          "FixedWindow": {
            "Enabled": true,
            "PermitLimit": 100,
            "Window": "00:01:00",
            "QueueLimit": 10
          },
          "SlidingWindow": {
            "Enabled": true,
            "PermitLimit": 100,
            "Window": "00:01:00",
            "SegmentsPerWindow": 6,
            "QueueLimit": 10
          },
          "TokenBucket": {
            "Enabled": true,
            "TokenLimit": 100,
            "ReplenishmentPeriod": "00:00:10",
            "TokensPerPeriod": 10,
            "AutoReplenishment": true,
            "QueueLimit": 10
          },
          "Concurrency": {
            "Enabled": true,
            "PermitLimit": 50,
            "QueueLimit": 100
          }
        }
      },
      "EventSourcing": {
        "Enabled": true,
        "Mode": "Hybrid",
        "Provider": "Marten",
        "ConnectionString": "Host=localhost;Database=GoodHamburgerEvents;Username=postgres;Password=postgres",
        "AuditEntities": [

        ],
        "StoreSnapshots": true,
        "SnapshotInterval": 10,
        "EnableAuditApi": true,
        "StoreMetadata": true
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*"
}
