@page "/"

<PageTitle>GoodHamburger | Início</PageTitle>

<section class="hero-card">
    <div class="hero-copy">
        <div class="hero-actions">
            <a class="primary-button" href="/produtos">Gestão de Produtos</a>
            <a class="secondary-button" href="/pedidos">Montar pedido</a>
        </div>
    </div>
</section>

<section class="page-grid page-grid--three">
    <article class="page-card">
        <p class="eyebrow">Produtos</p>
        <h2>Catálogo do Restaurante</h2>
        <p class="muted">Gestão completa de itens do cardápio, incluindo preços e disponibilidade.</p>
    </article>

    <article class="page-card">
        <p class="eyebrow">Pedido</p>
        <h2>Composição e total</h2>
        <p class="muted">Permite montar o pedido e visualizar o retorno calculado pela API, incluindo desconto.</p>
    </article>

    <article class="page-card">
        <p class="eyebrow">Auditoria</p>
        <h2>Event sourcing</h2>
        <p class="muted">Consulta histórico, estatísticas e replay dos eventos expostos publicamente.</p>
    </article>
</section>
