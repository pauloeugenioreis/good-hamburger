@page "/pedidos"
@using GoodHamburger.Domain.Entities
@inject IProductClient ProductClient
@inject IOrderClient OrderClient
@inject Microsoft.Extensions.Options.IOptions<ApiOptions> ApiSettings

<PageTitle>GoodHamburger | Pedidos</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Administração</p>
        <h1>Pedidos</h1>
    </div>
    <div class="toolbar-actions">
        <button class="secondary-button" type="button" @onclick="OpenNewOrder" disabled="@isLoading">Novo Pedido</button>
        <a class="primary-button" href="@ExportUrl" target="_blank" rel="noopener noreferrer">Exportar</a>
        <button class="secondary-button" type="button" @onclick="ReloadAsync" disabled="@isLoading">Recarregar</button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(actionMessage) && !isEditorOpen)
{
    <div class="inline-alert">@actionMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage) && !isEditorOpen)
{
    <div class="inline-alert inline-alert--error">@errorMessage</div>
}

<section class="products-layout">
    <article class="page-card products-list-card">
        
        <div class="products-list-header">
            <div class="stack-actions" style="flex: 1; align-items: center;">
                <div style="position: relative; flex: 1; max-width: 400px;">
                    <input class="input" placeholder="Buscar por ID / Nº / Cliente..." @bind="filterSearch" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                </div>
                <select class="input" style="max-width: 200px;" @bind="filterStatus">
                    <option value="">Todos os Status</option>
                    @foreach (var status in OrderStatus.AllowedStatuses)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
                <button class="primary-button" type="button" @onclick="() => LoadPageAsync(1)" disabled="@isLoading">Filtrar</button>
                <button class="secondary-button" type="button" @onclick="ClearFilters" disabled="@isLoading">Limpar</button>
            </div>
        </div>

        @if (isLoading && orders.Count == 0)
        {
            <div style="padding: 2rem; text-align: center;">
                <p class="muted">Carregando pedidos...</p>
            </div>
        }
        else if (orders.Count == 0 && !isLoading)
        {
            <div class="page-card page-card--centered page-card--highlight products-empty">
                <div>
                    <p class="eyebrow">Sem Resultados</p>
                    <h2>Nenhum pedido encontrado</h2>
                    <p class="muted">Tente ajustar seus filtros ou crie um novo pedido.</p>
                </div>
            </div>
        }
        else
        {
            <div class="products-table-wrap">
                <table class="products-table">
                    <thead>
                        <tr>
                            <th style="width: 80px">ID</th>
                            <th>Número</th>
                            <th>Data</th>
                            <th>Cliente</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th class="products-table__actions">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in orders)
                        {
                            <tr>
                                <td><span class="muted">#@order.Id</span></td>
                                <td>
                                    <div class="products-table__title">
                                        <strong>@order.OrderNumber</strong>
                                    </div>
                                </td>
                                <td>@order.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>
                                    <div class="products-table__title">
                                        <strong>@order.CustomerName</strong>
                                        <span class="muted">@order.CustomerEmail</span>
                                    </div>
                                </td>
                                <td>@FormatCurrency(order.Total)</td>
                                <td>
                                    <span class="status-pill @GetStatusClass(order.Status)">@order.Status</span>
                                </td>
                                <td>
                                    <div class="stack-actions stack-actions--compact">
                                        <button class="secondary-button" type="button" @onclick="() => EditOrder(order)">Editar</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="pagination-bar">
                <div class="pagination-bar__start">
                    <label class="field--inline">
                        <span class="muted">Itens:</span>
                        <select class="input" value="@pageSize" @onchange="OnPageSizeChanged">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                    </label>
                </div>

                @if (totalPages > 1)
                {
                    <div class="pagination-bar__center">
                        <button class="secondary-button" type="button" @onclick="PreviousPageAsync" disabled="@(!CanGoPrevious || isLoading)">Anterior</button>
                        <div class="pagination-bar__pages">
                            @for (var pageNumber = 1; pageNumber <= totalPages; pageNumber++)
                            {
                                var pageIndex = pageNumber;
                                <button class="pagination-button @(pageIndex == currentPage ? "pagination-button--active" : string.Empty)" type="button" @onclick="() => GoToPageAsync(pageIndex)" disabled="@(pageIndex == currentPage || isLoading)">
                                    @pageIndex
                                </button>
                            }
                        </div>
                        <button class="secondary-button" type="button" @onclick="NextPageAsync" disabled="@(!CanGoNext || isLoading)">Próxima</button>
                    </div>
                }

                <div class="pagination-bar__end">
                    <span class="status-pill status-pill--muted">Total: @totalOrders</span>
                </div>
            </div>
        }
    </article>

    <aside class="products-drawer @(isEditorOpen ? "products-drawer--open" : string.Empty)">
        <button class="drawer-backdrop" type="button" aria-label="Fechar editor" @onclick="CloseEditor"></button>

        <article class="page-card products-editor-card">
            <div class="drawer-header">
                <div>
                    <p class="eyebrow">@(isEditing ? "Gestão" : "Venda")</p>
                    <h2>@(isEditing ? $"Editar Pedido #{editingOrder?.Id}" : "Montar pedido")</h2>
                </div>
                <button class="secondary-button drawer-close" type="button" @onclick="CloseEditor">Fechar</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="inline-alert inline-alert--error" style="margin-bottom: 1.5rem;">@errorMessage</div>
            }

            <div class="form-grid form-grid--drawer">
                @if (isEditing && editingOrder != null)
                {
                    <p class="field--full eyebrow" style="margin-bottom: -1rem;">Status do Pedido</p>
                    <label class="field field--full">
                        <span>Situação Atual</span>
                        <select class="input" @bind="editingStatus" disabled="@isSubmitting">
                            @foreach (var status in OrderStatus.AllowedStatuses)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </label>
                }

                <p class="field--full eyebrow" style="margin: 1rem 0 -1rem 0;">Dados do cliente</p>
                <label class="field field--full">
                    <span>Nome</span>
                    <input class="input" @bind="customerName" disabled="@(isSubmitting || isEditing)" />
                </label>
                <label class="field field--full">
                    <span>E-mail</span>
                    <input class="input" @bind="customerEmail" disabled="@(isSubmitting || isEditing)" />
                </label>
                <label class="field field--full">
                    <span>Endereço</span>
                    <input class="input" @bind="shippingAddress" disabled="@(isSubmitting || isEditing)" />
                </label>

                @if (isEditing && editingOrder != null)
                {
                    <p class="field--full eyebrow" style="margin: 1rem 0 -1rem 0;">Resumo dos Itens</p>
                    <div class="field--full" style="margin-top: 1rem;">
                        <table class="products-table products-table--compact">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th style="text-align: right">Qtd.</th>
                                    <th style="text-align: right">Preço</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in editingOrder.Items)
                                {
                                    <tr>
                                        <td><strong>@item.ProductName</strong></td>
                                        <td style="text-align: right">@item.Quantity</td>
                                        <td style="text-align: right">@FormatCurrency(item.UnitPrice)</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="2" style="text-align: right"><strong>Total:</strong></td>
                                    <td style="text-align: right"><strong>@FormatCurrency(editingOrder.Total)</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <p class="field--full eyebrow" style="margin: 1rem 0 -1rem 0;">Itens do Cardápio</p>
                    <div class="field--full" style="margin-top: 1rem;">
                        <table class="products-table products-table--compact">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th style="text-align: right">Preço</th>
                                    <th style="text-align: right; width: 80px;">Qtd.</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in catalogItems)
                                {
                                    <tr>
                                        <td>
                                            <div class="products-table__title">
                                                <strong>@item.Name</strong>
                                                <span class="muted">@item.Category</span>
                                            </div>
                                        </td>
                                        <td style="text-align: right">@FormatCurrency(item.Price)</td>
                                        <td style="text-align: right">
                                            <input class="input" type="number" min="0" max="20" @bind="item.Quantity" 
                                                   style="width: 60px; padding: 0.25rem; text-align: center;" 
                                                   disabled="@isSubmitting" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="inline-alert inline-alert--error" style="margin-top: 1.5rem;">@errorMessage</div>
            }

            <div class="stack-actions" style="margin-top: 2rem;">
                @if (isEditing)
                {
                    <button class="primary-button" type="button" @onclick="UpdateStatusAsync" disabled="@isSubmitting">Salvar Alterações</button>
                    <button class="secondary-button" type="button" @onclick="CloseEditor" disabled="@isSubmitting">Cancelar</button>
                }
                else
                {
                    <button class="primary-button" type="button" @onclick="SubmitAsync" disabled="@isSubmitting">Finalizar Pedido</button>
                    <button class="secondary-button" type="button" @onclick="ResetSelection" disabled="@isSubmitting">Limpar</button>
                }
            </div>

            @if (isSubmitting)
            {
                <p class="muted" style="margin-top: 1rem;">Processando...</p>
            }
        </article>
    </aside>
</section>

@code {
    private readonly List<OrderResponseDto> orders = [];
    private readonly List<CatalogItem> catalogItems = [];
    
    // Filters
    private string filterSearch = string.Empty;
    private string filterStatus = string.Empty;
    
    // Form fields
    private string customerName = string.Empty;
    private string customerEmail = string.Empty;
    private string shippingAddress = string.Empty;
    
    // Edit state
    private bool isEditing;
    private OrderResponseDto? editingOrder;
    private string editingStatus = string.Empty;

    private bool isEditorOpen;
    private string? errorMessage;
    private string? actionMessage;
    private bool isLoading = true;
    private bool isSubmitting;
    
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private long totalOrders;

    private string ExportUrl => BuildExportUrl();
    private bool CanGoPrevious => currentPage > 1;
    private bool CanGoNext => currentPage < totalPages;

    protected override async Task OnInitializedAsync()
    {
        await LoadPageAsync(1);
        await LoadCatalogAsync();
    }

    private async Task ReloadAsync() => await LoadPageAsync(currentPage);

    private async Task LoadPageAsync(int page)
    {
        isLoading = true;
        errorMessage = null;

        long? idFilter = null;
        string? numberFilter = null;
        string? searchTerm = null;

        if (!string.IsNullOrWhiteSpace(filterSearch))
        {
            if (long.TryParse(filterSearch, out var id)) idFilter = id;
            else if (filterSearch.StartsWith("ORD-", StringComparison.OrdinalIgnoreCase)) numberFilter = filterSearch;
            else searchTerm = filterSearch;
        }

        var result = await OrderClient.GetOrdersAsync(
            id: idFilter,
            status: string.IsNullOrEmpty(filterStatus) ? null : filterStatus,
            orderNumber: numberFilter,
            searchTerm: searchTerm,
            page: page, 
            pageSize: pageSize);

        if (result.IsSuccess && result.Value is not null)
        {
            orders.Clear();
            orders.AddRange(result.Value.Items);
            currentPage = result.Value.Page;
            totalPages = result.Value.TotalPages;
            totalOrders = result.Value.Total;
        }
        else
        {
            errorMessage = result.ErrorMessage ?? "Não foi possível carregar os pedidos.";
        }

        isLoading = false;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadPageAsync(1);
    }

    private async Task ClearFilters()
    {
        filterSearch = string.Empty;
        filterStatus = string.Empty;
        await LoadPageAsync(1);
    }

    private async Task LoadCatalogAsync()
    {
        var result = await ProductClient.GetMenuAsync();
        if (result.IsSuccess && result.Value is not null)
        {
            catalogItems.Clear();
            catalogItems.AddRange(result.Value.Sandwiches.Select(MapItem));
            catalogItems.AddRange(result.Value.SideDishes.Select(MapItem));
        }
    }

    private CatalogItem MapItem(MenuItemDto item) => new()
    {
        Id = item.Id,
        Name = item.Name,
        Price = item.Price,
        Category = item.Category,
        Quantity = 0
    };

    private async Task SubmitAsync()
    {
        errorMessage = null;
        var items = catalogItems
            .Where(item => item.Quantity > 0)
            .Select(item => new OrderItemDto(item.Id, item.Quantity, item.Price))
            .ToList();

        if (items.Count == 0)
        {
            errorMessage = "Selecione ao menos um item.";
            return;
        }

        isSubmitting = true;
        var request = new CreateOrderRequest
        {
            CustomerName = customerName,
            CustomerEmail = customerEmail,
            ShippingAddress = shippingAddress,
            Items = items
        };

        var result = await OrderClient.CreateOrderAsync(request);
        if (result.IsSuccess)
        {
            actionMessage = $"Pedido {result.Value?.OrderNumber} criado com sucesso!";
            CloseEditor();
            ResetSelection();
            await ReloadAsync();
        }
        else
        {
            errorMessage = result.ErrorMessage ?? "Erro ao criar pedido.";
        }
        isSubmitting = false;
    }

    private async Task UpdateStatusAsync()
    {
        if (editingOrder == null || string.IsNullOrEmpty(editingStatus)) return;

        isSubmitting = true;
        errorMessage = null;

        var request = new UpdateOrderStatusDto(editingStatus, $"Status atualizado via Dashboard por Admin em {DateTime.Now:g}");
        var result = await OrderClient.UpdateOrderStatusAsync(editingOrder.Id, request);

        if (result.IsSuccess)
        {
            actionMessage = $"Status do pedido {editingOrder.OrderNumber} atualizado para '{editingStatus}'!";
            CloseEditor();
            await ReloadAsync();
        }
        else
        {
            errorMessage = result.ErrorMessage ?? "Erro ao atualizar status do pedido.";
        }

        isSubmitting = false;
    }

    private void OpenNewOrder()
    {
        isEditing = false;
        editingOrder = null;
        errorMessage = null;
        actionMessage = null;
        ResetSelection();
        customerName = string.Empty;
        customerEmail = string.Empty;
        shippingAddress = string.Empty;
        isEditorOpen = true;
    }

    private void EditOrder(OrderResponseDto order)
    {
        isEditing = true;
        editingOrder = order;
        editingStatus = order.Status;
        customerName = order.CustomerName;
        customerEmail = order.CustomerEmail;
        shippingAddress = order.ShippingAddress;
        errorMessage = null;
        actionMessage = null;
        isEditorOpen = true;
    }

    private void CloseEditor()
    {
        isEditorOpen = false;
        errorMessage = null;
    }

    private void ResetSelection()
    {
        foreach (var item in catalogItems) item.Quantity = 0;
    }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            pageSize = size;
            await LoadPageAsync(1);
        }
    }

    private async Task GoToPageAsync(int page) => await LoadPageAsync(page);
    private async Task PreviousPageAsync() => await LoadPageAsync(currentPage - 1);
    private async Task NextPageAsync() => await LoadPageAsync(currentPage + 1);

    private string GetStatusClass(string status) => status switch
    {
        "Pendente" => "status-pill--muted",
        "Em Processamento" => "status-pill--info",
        "Enviado" => "status-pill--warning",
        "Entregue" => "status-pill--success",
        "Cancelado" => "status-pill--error",
        _ => "status-pill--info"
    };

    private string BuildExportUrl()
    {
        var baseUrl = ApiSettings.Value.BaseUrl;
        if (!Uri.TryCreate(baseUrl, UriKind.Absolute, out var baseUri)) baseUri = new Uri("https://localhost:3060/");
        return new Uri(baseUri, "api/v1/Order/ExportToExcel").ToString();
    }

    private static string FormatCurrency(decimal value) => value.ToString("C", CultureInfo.GetCultureInfo("pt-BR"));

    private sealed class CatalogItem
    {
        public long Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public string Category { get; set; } = string.Empty;
        public int Quantity { get; set; }
    }
}
