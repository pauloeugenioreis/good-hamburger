# ==============================================================================
# .NET 10 Clean Architecture Template - Environment Variables Example
# ==============================================================================
# Copy this file to .env and update with your values.
# DO NOT commit .env file to version control.
#
# Uses the standard .NET configuration convention:
#   Section__SubSection__Property (double underscore as separator)
# Maps directly to appsettings.json / AppSettings.cs hierarchy.
# ==============================================================================

# ------------------------------------------------------------------------------
# ASP.NET Core (native framework variables)
# ------------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ------------------------------------------------------------------------------
# AppSettings > EnvironmentName
# ------------------------------------------------------------------------------
AppSettings__EnvironmentName=Development

# ------------------------------------------------------------------------------
# Database (AppSettings > Infrastructure > Database)
# ------------------------------------------------------------------------------
# DatabaseType options: InMemory, SqlServer, PostgreSQL, MySQL, Oracle
AppSettings__Infrastructure__Database__DatabaseType=SqlServer
AppSettings__Infrastructure__Database__ConnectionString=Server=localhost;Database=ProjectTemplate;User Id=sa;Password=YourStrong@Password123;TrustServerCertificate=True;
# AppSettings__Infrastructure__Database__ReadOnlyConnectionString=
AppSettings__Infrastructure__Database__CommandTimeoutSeconds=30
AppSettings__Infrastructure__Database__EnableSensitiveDataLogging=false
AppSettings__Infrastructure__Database__EnableDetailedErrors=false

# PostgreSQL (Alternative)
# AppSettings__Infrastructure__Database__DatabaseType=PostgreSQL
# AppSettings__Infrastructure__Database__ConnectionString=Host=localhost;Port=5432;Database=projecttemplate;Username=postgres;Password=YourPassword123;

# MySQL (Alternative)
# AppSettings__Infrastructure__Database__DatabaseType=MySQL
# AppSettings__Infrastructure__Database__ConnectionString=Server=localhost;Port=3306;Database=projecttemplate;User=root;Password=YourPassword123;

# Oracle (Alternative)
# AppSettings__Infrastructure__Database__DatabaseType=Oracle
# AppSettings__Infrastructure__Database__ConnectionString=User Id=system;Password=YourPassword123;Data Source=localhost:1521/XE;

# ------------------------------------------------------------------------------
# Cache (AppSettings > Infrastructure > Cache)
# ------------------------------------------------------------------------------
# Provider options: Memory, Redis, SqlServer
AppSettings__Infrastructure__Cache__Enabled=true
AppSettings__Infrastructure__Cache__Provider=Memory
AppSettings__Infrastructure__Cache__DefaultExpirationMinutes=60
# AppSettings__Infrastructure__Cache__ConnectionString=

# Redis (Production)
# AppSettings__Infrastructure__Cache__Provider=Redis
# AppSettings__Infrastructure__Cache__ConnectionString=localhost:6379,password=YourRedisPassword,ssl=false,abortConnect=false

# ------------------------------------------------------------------------------
# Storage (AppSettings > Infrastructure > Storage)
# ------------------------------------------------------------------------------
# Provider options: Google, Azure, Aws
# AppSettings__Infrastructure__Storage__Provider=Google
# AppSettings__Infrastructure__Storage__DefaultBucket=your-bucket-name

# Google Cloud Storage
# AppSettings__Infrastructure__Storage__Google__ServiceAccount=
# AppSettings__Infrastructure__Storage__Google__ProjectId=

# Azure Blob Storage
# AppSettings__Infrastructure__Storage__Provider=Azure
# AppSettings__Infrastructure__Storage__Azure__ConnectionString=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
# AppSettings__Infrastructure__Storage__Azure__BlobServiceUri=
# AppSettings__Infrastructure__Storage__Azure__ManagedIdentityClientId=

# AWS S3
# AppSettings__Infrastructure__Storage__Provider=Aws
# AppSettings__Infrastructure__Storage__Aws__AccessKeyId=
# AppSettings__Infrastructure__Storage__Aws__SecretAccessKey=
# AppSettings__Infrastructure__Storage__Aws__Region=us-east-1
# AppSettings__Infrastructure__Storage__Aws__Profile=
# AppSettings__Infrastructure__Storage__Aws__ServiceUrl=

# ------------------------------------------------------------------------------
# Telemetry (AppSettings > Infrastructure > Telemetry)
# ------------------------------------------------------------------------------
AppSettings__Infrastructure__Telemetry__Enabled=false
# Providers array uses numeric index: Providers__0, Providers__1, etc.
# AppSettings__Infrastructure__Telemetry__Providers__0=jaeger
# AppSettings__Infrastructure__Telemetry__Providers__1=prometheus
AppSettings__Infrastructure__Telemetry__SamplingRatio=1.0
AppSettings__Infrastructure__Telemetry__EnableSqlInstrumentation=true
AppSettings__Infrastructure__Telemetry__EnableHttpInstrumentation=true

# Jaeger
# AppSettings__Infrastructure__Telemetry__Jaeger__Host=localhost
# AppSettings__Infrastructure__Telemetry__Jaeger__Port=4317
# AppSettings__Infrastructure__Telemetry__Jaeger__UseGrpc=true

# Zipkin
# AppSettings__Infrastructure__Telemetry__Zipkin__Endpoint=http://localhost:9411/api/v2/spans

# OTLP (OpenTelemetry Protocol)
# AppSettings__Infrastructure__Telemetry__Otlp__Endpoint=http://localhost:4317
# AppSettings__Infrastructure__Telemetry__Otlp__Protocol=grpc
# AppSettings__Infrastructure__Telemetry__Otlp__Headers=

# Application Insights
# AppSettings__Infrastructure__Telemetry__ApplicationInsights__ConnectionString=InstrumentationKey=your-key;IngestionEndpoint=https://region.in.applicationinsights.azure.com/
# AppSettings__Infrastructure__Telemetry__ApplicationInsights__EnableAdaptiveSampling=true
# AppSettings__Infrastructure__Telemetry__ApplicationInsights__EnableLiveMetrics=true

# Datadog
# AppSettings__Infrastructure__Telemetry__Datadog__Endpoint=http://localhost:4317
# AppSettings__Infrastructure__Telemetry__Datadog__ApiKey=
# AppSettings__Infrastructure__Telemetry__Datadog__Site=datadoghq.com
# AppSettings__Infrastructure__Telemetry__Datadog__Environment=development

# Dynatrace
# AppSettings__Infrastructure__Telemetry__Dynatrace__Endpoint=
# AppSettings__Infrastructure__Telemetry__Dynatrace__ApiToken=
# AppSettings__Infrastructure__Telemetry__Dynatrace__Environment=development

# ------------------------------------------------------------------------------
# Rate Limiting (AppSettings > Infrastructure > RateLimiting)
# ------------------------------------------------------------------------------
AppSettings__Infrastructure__RateLimiting__Enabled=false
# AppSettings__Infrastructure__RateLimiting__DefaultPolicy=fixed
# WhitelistedIps array uses numeric index
# AppSettings__Infrastructure__RateLimiting__WhitelistedIps__0=127.0.0.1

# Fixed Window Policy
# AppSettings__Infrastructure__RateLimiting__Policies__FixedWindow__Enabled=true
# AppSettings__Infrastructure__RateLimiting__Policies__FixedWindow__PermitLimit=100
# AppSettings__Infrastructure__RateLimiting__Policies__FixedWindow__Window=00:01:00
# AppSettings__Infrastructure__RateLimiting__Policies__FixedWindow__QueueLimit=10

# Sliding Window Policy
# AppSettings__Infrastructure__RateLimiting__Policies__SlidingWindow__Enabled=true
# AppSettings__Infrastructure__RateLimiting__Policies__SlidingWindow__PermitLimit=100
# AppSettings__Infrastructure__RateLimiting__Policies__SlidingWindow__Window=00:01:00
# AppSettings__Infrastructure__RateLimiting__Policies__SlidingWindow__SegmentsPerWindow=6
# AppSettings__Infrastructure__RateLimiting__Policies__SlidingWindow__QueueLimit=10

# Token Bucket Policy
# AppSettings__Infrastructure__RateLimiting__Policies__TokenBucket__Enabled=true
# AppSettings__Infrastructure__RateLimiting__Policies__TokenBucket__TokenLimit=100
# AppSettings__Infrastructure__RateLimiting__Policies__TokenBucket__ReplenishmentPeriod=00:00:10
# AppSettings__Infrastructure__RateLimiting__Policies__TokenBucket__TokensPerPeriod=10
# AppSettings__Infrastructure__RateLimiting__Policies__TokenBucket__AutoReplenishment=true
# AppSettings__Infrastructure__RateLimiting__Policies__TokenBucket__QueueLimit=10

# Concurrency Policy
# AppSettings__Infrastructure__RateLimiting__Policies__Concurrency__Enabled=true
# AppSettings__Infrastructure__RateLimiting__Policies__Concurrency__PermitLimit=50
# AppSettings__Infrastructure__RateLimiting__Policies__Concurrency__QueueLimit=100

# ------------------------------------------------------------------------------
# Event Sourcing (AppSettings > Infrastructure > EventSourcing)
# ------------------------------------------------------------------------------
AppSettings__Infrastructure__EventSourcing__Enabled=false
# AppSettings__Infrastructure__EventSourcing__Mode=Hybrid
# AppSettings__Infrastructure__EventSourcing__Provider=Marten
# AppSettings__Infrastructure__EventSourcing__ConnectionString=Host=localhost;Database=ProjectTemplateEvents;Username=postgres;Password=postgres
# AppSettings__Infrastructure__EventSourcing__StoreSnapshots=true
# AppSettings__Infrastructure__EventSourcing__SnapshotInterval=10
# AppSettings__Infrastructure__EventSourcing__EnableAuditApi=true
# AppSettings__Infrastructure__EventSourcing__StoreMetadata=true
# AuditEntities array uses numeric index
# AppSettings__Infrastructure__EventSourcing__AuditEntities__0=Order

# ------------------------------------------------------------------------------
# RabbitMQ (AppSettings > Infrastructure > RabbitMQ)
# ------------------------------------------------------------------------------
# AppSettings__Infrastructure__RabbitMQ__ConnectionString=amqp://guest:guest@localhost:5672/

# ------------------------------------------------------------------------------
# MongoDB (AppSettings > Infrastructure > MongoDB)
# ------------------------------------------------------------------------------
# AppSettings__Infrastructure__MongoDB__ConnectionString=mongodb://localhost:27017/projecttemplate

# ------------------------------------------------------------------------------
# Authentication (AppSettings > Authentication)
# ------------------------------------------------------------------------------
AppSettings__Authentication__Enabled=true

# JWT
AppSettings__Authentication__Jwt__Secret=your-256-bit-secret-key-change-this-in-production-needs-at-least-32-characters
AppSettings__Authentication__Jwt__Issuer=ProjectTemplate
AppSettings__Authentication__Jwt__Audience=ProjectTemplate
AppSettings__Authentication__Jwt__ExpirationMinutes=60
AppSettings__Authentication__Jwt__RefreshTokenExpirationDays=7
AppSettings__Authentication__Jwt__ValidateIssuer=true
AppSettings__Authentication__Jwt__ValidateAudience=true
AppSettings__Authentication__Jwt__ValidateLifetime=true
AppSettings__Authentication__Jwt__ValidateIssuerSigningKey=true

# OAuth2
# AppSettings__Authentication__OAuth2__Enabled=false

# OAuth2 > Google
# AppSettings__Authentication__OAuth2__Google__Enabled=false
# AppSettings__Authentication__OAuth2__Google__ClientId=
# AppSettings__Authentication__OAuth2__Google__ClientSecret=

# OAuth2 > Microsoft
# AppSettings__Authentication__OAuth2__Microsoft__Enabled=false
# AppSettings__Authentication__OAuth2__Microsoft__ClientId=
# AppSettings__Authentication__OAuth2__Microsoft__ClientSecret=
# AppSettings__Authentication__OAuth2__Microsoft__TenantId=common

# OAuth2 > GitHub
# AppSettings__Authentication__OAuth2__GitHub__Enabled=false
# AppSettings__Authentication__OAuth2__GitHub__ClientId=
# AppSettings__Authentication__OAuth2__GitHub__ClientSecret=

# Password Policy
# AppSettings__Authentication__PasswordPolicy__MinimumLength=8
# AppSettings__Authentication__PasswordPolicy__RequireDigit=true
# AppSettings__Authentication__PasswordPolicy__RequireLowercase=true
# AppSettings__Authentication__PasswordPolicy__RequireUppercase=true
# AppSettings__Authentication__PasswordPolicy__RequireNonAlphanumeric=true
# AppSettings__Authentication__PasswordPolicy__MaxFailedAccessAttempts=5
# AppSettings__Authentication__PasswordPolicy__LockoutMinutes=15

# Refresh Token
# AppSettings__Authentication__RefreshToken__ExpirationDays=7
# AppSettings__Authentication__RefreshToken__ReuseTokens=false

# ------------------------------------------------------------------------------
# Logging (standard .NET logging configuration)
# ------------------------------------------------------------------------------
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
Logging__LogLevel__Microsoft.EntityFrameworkCore=Information

# OpenTelemetry
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=projecttemplate-api
# OTEL_SERVICE_VERSION=1.0.0

# ------------------------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:4200,https://yourapp.com
CORS_ALLOW_CREDENTIALS=true

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ------------------------------------------------------------------------------
# Health Checks
# ------------------------------------------------------------------------------
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_READY_PATH=/health/ready

# ------------------------------------------------------------------------------
# Swagger Configuration
# ------------------------------------------------------------------------------
SWAGGER_ENABLED=true
SWAGGER_ENDPOINT=/swagger
SWAGGER_TITLE=ProjectTemplate API
SWAGGER_VERSION=v1

# ------------------------------------------------------------------------------
# Kubernetes (Production)
# ------------------------------------------------------------------------------
# K8S_NAMESPACE=projecttemplate
# K8S_SERVICE_NAME=projecttemplate-api
# K8S_CLUSTER_NAME=production-cluster

# ------------------------------------------------------------------------------
# Docker Configuration
# ------------------------------------------------------------------------------
# DOCKER_REGISTRY=youracr.azurecr.io
# DOCKER_IMAGE_NAME=projecttemplate-api
# DOCKER_IMAGE_TAG=latest

# ------------------------------------------------------------------------------
# Feature Flags (Future)
# ------------------------------------------------------------------------------
# FEATURE_NEW_DASHBOARD=true
# FEATURE_BETA_API=false
# FEATURE_ANALYTICS=true

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# HTTPS_PORT=5001
# SSL_CERTIFICATE_PATH=/app/certificates/cert.pfx
# SSL_CERTIFICATE_PASSWORD=YourCertPassword

# ------------------------------------------------------------------------------
# Performance
# ------------------------------------------------------------------------------
MAX_REQUEST_BODY_SIZE=10485760
REQUEST_TIMEOUT_SECONDS=30
ENABLE_RESPONSE_COMPRESSION=true

# ------------------------------------------------------------------------------
# Development Tools
# ------------------------------------------------------------------------------
ENABLE_SWAGGER_UI=true
ENABLE_DEVELOPER_EXCEPTION_PAGE=true
ENABLE_DETAILED_ERRORS=true

# ------------------------------------------------------------------------------
# Background Jobs (Future)
# ------------------------------------------------------------------------------
# HANGFIRE_CONNECTION_STRING=Server=localhost;Database=ProjectTemplateHangfire;User Id=sa;Password=YourPassword123;TrustServerCertificate=True;
# HANGFIRE_DASHBOARD_PATH=/hangfire
# HANGFIRE_WORKERS=5

# ==============================================================================
# IMPORTANT NOTES:
# ==============================================================================
# 1. Never commit .env file with real credentials to source control
# 2. Use Azure Key Vault, AWS Secrets Manager, or similar for production secrets
# 3. Rotate credentials regularly
# 4. Use different credentials for each environment (dev, staging, prod)
# 5. Follow the principle of least privilege
# ==============================================================================
